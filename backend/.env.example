OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
APP_ENV=development
DATABASE_URL=sqlite:///./comptapilot.db
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-in-production
AUTH_REQUIRED=true

# Même clé Web API que VITE_FIREBASE_API_KEY (Firebase Console → Paramètres projet)
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=

# Stripe Billing — ComptaPilot Pro 19 €/mois, essai de 14 jours
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_TRIAL_DAYS=14
STRIPE_PAST_DUE_GRACE_DAYS=3
SUBSCRIPTION_TERMS_VERSION=v1
# Token pour POST /api/subscriptions/jobs/trial-reminders (cron Render/externe)
SUBSCRIPTION_CRON_TOKEN=
FRONTEND_URL=http://localhost:5173
# Prod : https://elfis-core.com (Stripe success/cancel + liens d'invitation)
# URL publique HTTPS de l’API (Render) — pour avatars / liens absolus
PUBLIC_API_URL=https://elfis-core-api.onrender.com

# Adresses séparées par des virgules (super-admin ELFIS)
PLATFORM_ADMIN_EMAILS=johnjuniort40@gmail.com

# E-mail transactionnel plateforme (ComptaPilot) — jamais une clé par client
# Option A (recommandé si Key not found) : SMTP Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Option B : API Brevo (clé xkeysib-… — pas MCP)
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=
PLATFORM_EMAIL_FROM=documents@elfiscore.com
PLATFORM_EMAIL_FROM_NAME=ComptaPilot
# Alias rétrocompatible (utilisé si PLATFORM_EMAIL_FROM vide)
SMTP_FROM=
# Secours SMTP (local / serveur sans restriction)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Chiffrement des jetons OAuth / mots de passe SMTP org (Fernet url-safe 32 bytes)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_CREDENTIALS_ENCRYPTION_KEY=

# Google OAuth (Gmail send)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/email-connections/oauth/google/callback

# Microsoft OAuth (Graph Mail.Send)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8000/api/email-connections/oauth/microsoft/callback
